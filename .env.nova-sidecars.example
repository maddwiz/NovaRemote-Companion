# Copy to .env.nova-sidecars and customize before running the sidecars.

# Where the sibling NovaAdapt checkout lives. Override if your checkout is elsewhere.
NOVAADAPT_REPO_PATH=../NovaAdapt

# Core / bridge auth
NOVAADAPT_CORE_TOKEN=change-me-core-token
NOVAADAPT_BRIDGE_TOKEN=change-me-bridge-token

# Optional NovaSpine auth
NOVASPINE_TOKEN=change-me-spine-token

# Optional NovaAdapt memory wiring
NOVAADAPT_MEMORY_BACKEND=novaspine-http
NOVAADAPT_SPINE_URL=http://novaspine:8420
NOVAADAPT_SPINE_TOKEN=${NOVASPINE_TOKEN}

# Optional model/provider settings passed into the NovaAdapt core container.
# Adjust these to match the model config and provider you want to use.
NOVAADAPT_OPENAI_API_KEY=
NOVAADAPT_ANTHROPIC_API_KEY=
NOVAADAPT_OLLAMA_HOST=http://host.docker.internal:11434
